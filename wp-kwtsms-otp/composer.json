{
  "name": "kwtsms/wp-kwtsms-otp",
  "description": "SMS OTP authentication for WordPress via kwtsms gateway",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "wp-phpunit/wp-phpunit": "^6.4",
    "brain/monkey": "^2.6",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "phpstan/phpstan": "^2.0",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "autoload-dev": {
    "psr-4": {
      "KwtSMS\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "phpstan": "phpstan analyse --configuration phpstan.neon",
    "phpcs": "phpcs --standard=WordPress includes/ admin/ wp-kwtsms-otp.php"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
