includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - includes/
        - admin/
        - wp-kwtsms-otp.php
        - uninstall.php

    excludePaths:
        - vendor/
        - tests/

    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
