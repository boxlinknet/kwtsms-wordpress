msgstr "بيانات الاعتماد"

msgid "API Username"
msgstr "اسم المستخدم"

msgid "API Password"
msgstr "كلمة المرور"

msgid "Your kwtsms account username."
msgstr "اسم المستخدم لحساب kwtsms."

msgid ""
"Your kwtsms account password. Stored server-side only, never exposed to the "
"browser."
msgstr ""
"كلمة مرور حساب kwtsms. مخزنة من جانب الخادم فقط، لا تُعرض في المتصفح أبداً."

msgid "Sender ID"
msgstr "معرّف المرسل"

