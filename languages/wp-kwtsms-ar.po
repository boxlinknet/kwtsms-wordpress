msgid "Gateway"
msgstr "البوابة"

msgid "Templates"
msgstr "القوالب"

msgid "Two-Factor Authentication (2FA) — password + OTP"
msgstr "المصادقة الثنائية (2FA) — كلمة المرور + رمز التحقق"

msgid "Passwordless — phone + OTP only"
msgstr "بدون كلمة مرور — رقم الهاتف + رمز التحقق فقط"

